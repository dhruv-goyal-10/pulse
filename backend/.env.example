# --- Database ---
DATABASE_URL=postgresql+asyncpg://pulse:pulse@localhost:5432/pulse
DATABASE_URL_SYNC=postgresql+psycopg2://pulse:pulse@localhost:5432/pulse

# --- JWT ---
JWT_SECRET_KEY=change-me-run-python-c-import-secrets-print-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Google OAuth (optional; leave blank to disable Google login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Frontend / CORS ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Demo login (seeded automatically) ---
DEMO_EMAIL=demo@pulse.app
DEMO_PASSWORD=demo123
DEMO_NAME=Demo Admin

# --- App ---
APP_ENV=development
